{
  "name": "farcrystal",
  "private": true,
  "version": "1.0.0",
  "description": "AI-Powered Farcaster Mini App on Base",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:push": "cd packages/database && prisma db push",
    "db:migrate": "cd packages/database && prisma migrate dev",
    "contracts:compile": "cd packages/contracts && hardhat compile",
    "contracts:deploy": "cd packages/contracts && hardhat run scripts/deploy.ts --network base-sepolia"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "turbo": "^1.12.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=22.11.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}
